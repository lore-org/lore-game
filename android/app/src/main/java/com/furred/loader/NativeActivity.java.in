package com.furred.loader;

import org.libsdl.app.SDLActivity;

import android.util.Log;
import android.content.Context;

import java.io.File;
import java.io.IOException;
import java.nio.file.Files;
import java.nio.file.Path;
import java.nio.file.Paths;
import java.util.Arrays;
import java.util.stream.Stream;

public class NativeActivity extends SDLActivity {
    @Override
    protected String getMainFunction() {
        return "main";
    }

    @Override
    protected String getMainSharedObject() {
        String library = "lib" + NativeActivity.getMainLib() + ".so";
        return this.getFullLibPath() + "/" + library;
    }

    @Override
    protected String[] getLibraries() {
        String jniLibs = this.getFullLibPath();

        Log.i("com.furred.loader.NativeActivity", "Found jniLibs path: " + jniLibs);

        String[] libraries = NativeActivity.readDirectory(jniLibs)
            .map(library -> library.substring(library.startsWith("lib") ? 3 : 0, library.length() - 3))
            .toArray(String[]::new);

        Log.i("com.furred.loader.NativeActivity", "Found libraries: " + Arrays.toString(libraries));

        return libraries;
    }

    public static Stream<String> readDirectory(String directory) {
        File dir = new File(directory);

        // FIXME - Error is triggered on sourceDir
        try {
            String[] list = dir.list();
            if (dir == null) throw new IOException(directory);
            
            return Arrays.stream(list);
        } catch (IOException e) {
            Log.e("com.furred.loader.NativeActivity", "Error reading directory: " + e.getLocalizedMessage());
            return Stream.empty();
        }
    }

    public String getFullLibPath() {
        return getApplicationContext().getApplicationInfo().sourceDir + "/lib/" + NativeActivity.getLibPath();
    }

    public static String getLibPath() {
        return "@CMAKE_ANDROID_ARCH_ABI@";
    }

    public static String getMainLib() {
        return "@SANITISED_APP_NAME@";
    }
}
