    {
        "version": "2.0.0",
        "tasks": [
            {
                "label": "(make) compile",
                "type": "shell",
                "command": "make",
                "args": [
                    "compile"
                ],
                "group": {
                    "kind": "build",
                    "isDefault": true
                },
                "problemMatcher": [
                    "$gcc"
                ],
                "detail": "Build the project"
            },
            {
                "label": "(cmake) compile",
                "type": "shell",
                "command": "cmake",
                "args": [
                    "-DCMAKE_BUILD_TYPE=Debug",
                    "-DCMAKE_CXX_COMPILER=g++",
                    "-DCMAKE_C_COMPILER=gcc",
                    "-S", "${workspaceFolder}",
                    "-B", "build",
                    "-G", "Unix Makefiles"
                ],
                "group": {
                    "kind": "build",
                    "isDefault": true
                },
                "problemMatcher": [
                    "$gcc"
                ],
                "detail": "Build the project"
            }
        ]
    }